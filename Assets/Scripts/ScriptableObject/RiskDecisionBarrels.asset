  m_Script: {fileID: 11500000, guid: 449cfd18af9407e4fb36daa82fd738e5, type: 3}
  m_Name: RiskDecisionBarrels
  m_EditorClassIdentifier: 
  intruction: 'Warning: Chemical Hazard<br>A potential chemical risk is present in
    this area.<br>Carefully observe your surroundings and identify the object that
    represents a risk by clicking on it'
  question: What is the safest action to take in this situation?
  answers:
  - Move the barrel without protective equipment
  - Secure the overturned barrel and prevent any chemical spill
  - Ignore the barrel and continue working as usual
  correctIndex: 1
  securedText: Risk secured.<br>The chemical hazard has been properly handled.<br>Good
    job. You may proceed to the next area
