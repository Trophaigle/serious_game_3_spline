  m_Script: {fileID: 11500000, guid: 449cfd18af9407e4fb36daa82fd738e5, type: 3}
  m_Name: RiskDecisionElec
  m_EditorClassIdentifier: 
  intruction: 'Warning: Electrical Hazard<br>An electrical risk has been detected
    in this area.<br>Inspect the environment and identify the hazardous object by
    clicking on it'
  question: What is the correct behavior when facing this electrical risk?
  answers:
  - Touch the equipment to check if it is still powered
  - Isolate the power source and secure the electrical panel
  - Leave the area without reporting the issue
  correctIndex: 1
  securedText: Risk secured.<br>The electrical hazard has been eliminated safely.<br>You
    can now continue.
